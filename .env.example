EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
POSTHOG_PROJECT_TOKEN=phc_your_posthog_project_token
POSTHOG_HOST=https://us.i.posthog.com
STREAM_API_KEY=your_stream_api_key
STREAM_API_SECRET=your_stream_api_secret
# Base URL of the vision-agent HTTP service ("uv run agent.py serve"), and the
# shared secret it's configured with (AGENT_SERVICE_API_KEY in vision-agent/.env).
# Server-side only — see app/api/agent/start+api.ts and stop+api.ts.
AGENT_SERVICE_URL=http://localhost:8000
AGENT_SERVICE_API_KEY=your_agent_service_shared_secret
